{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>damacus/renovate-config"
  ],
  "packageRules": [
    {
      "description": "Automerge GitHub Actions updates after required checks pass.",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge JavaScript dependency updates after required checks pass.",
      "matchManagers": [
        "npm"
      ],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr"
    }
  ]
}
